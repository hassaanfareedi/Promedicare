# Copy to `.env.local` and fill in real values.
# Never commit `.env.local` or real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-only. Required for:
# - `npm run seed`
# - Hospital admin "New doctor" (auth.admin.createUser via service role)
# Set the same value on Vercel for production doctor creation.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq AI (OpenAI-compatible). Without this, screening uses a safe placeholder.
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# App URL used for OAuth and password-reset redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: run Playwright against a deployed URL
# PLAYWRIGHT_BASE_URL=https://your-app.vercel.app

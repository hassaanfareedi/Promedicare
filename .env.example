# ProMediCare AI — environment variables
# Copy this file to .env.local and fill in real values. Never commit secrets.

# --- Supabase (required) ---
# Public project URL and anon key (safe to expose to the browser; RLS is the boundary).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key for privileged server-only operations (account creation,
# audit writes, tenant repair). NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site (required for correct auth redirects and metadata) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Groq AI (optional; symptom screening falls back to a safe placeholder if unset) ---
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- E2E tests (optional) ---
PLAYWRIGHT_BASE_URL=http://localhost:3000
